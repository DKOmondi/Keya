<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DKO Portfolio 2026 — Midnight Teal</title>
<!-- THEME 4 · Midnight Blue + Electric Teal · Space Grotesk + DM Sans -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#050C14;--bg2:#0A1520;--alt:#081220;--surface:#0F1E2E;
  --acc:#0ABFCC;--acc2:#12D4E0;--acc3:#088A94;--acc-glow:rgba(10,191,204,.12);
  --txt:#E0F0F4;--txt2:#9ABAC4;--muted:#4A7080;
  --border:#142030;--border2:#1E3040;--ok:#0ABFCC;
  --fh:'Space Grotesk',sans-serif; --fb:'DM Sans',sans-serif;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{font-size:15px;scroll-behavior:smooth;}
body{font-family:var(--fb);background:var(--bg);color:var(--txt);overflow-x:hidden;line-height:1.65;}
h1,h2,h3,h4,h5{font-family:var(--fh);line-height:1.15;letter-spacing:-0.02em;}
p{color:var(--txt2);margin-bottom:.7em;}a{color:var(--acc);text-decoration:none;}a:hover{color:var(--acc2);}
strong,b{font-weight:600;color:var(--txt);}
/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:52px;display:flex;align-items:center;
  justify-content:space-between;padding:0 40px;
  background:rgba(0,0,0,0);backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);}
.dark-nav nav{background:rgba(5,5,5,0.92);}
.light-nav nav{background:rgba(247,243,238,0.95);}
.nav-brand{font-family:var(--fh);font-weight:700;font-size:.95rem;letter-spacing:.04em;color:var(--txt);}
.nav-dot{color:var(--acc);}
.nav-links{display:flex;gap:28px;}
.nav-links a{font-size:.74rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);font-weight:500;transition:color .2s;}
.nav-links a:hover{color:var(--acc);}
.nav-cta{background:var(--acc) !important;color:#fff !important;padding:6px 18px;border-radius:4px;font-weight:600 !important;}
.nav-cta:hover{background:var(--acc2) !important;color:#fff !important;}
/* HERO */
#hero{min-height:100vh;padding-top:52px;display:flex;align-items:center;position:relative;overflow:hidden;}
.hero-inner{position:relative;z-index:2;max-width:1140px;margin:0 auto;padding:80px 40px;
  display:grid;grid-template-columns:1.15fr .85fr;gap:72px;align-items:center;}
.hero-tag{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--acc-glow);
  border-radius:4px;padding:5px 14px;margin-bottom:28px;font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;}
.htdot{width:6px;height:6px;border-radius:50%;background:var(--acc);animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.7)}}
.hero-tag span{color:var(--acc);font-weight:500;}
.hero-name{font-size:clamp(3rem,6.5vw,5.2rem);font-weight:800;color:var(--txt);line-height:1.0;margin-bottom:12px;}
.hero-name em{color:var(--acc);font-style:normal;display:block;}
.hero-role{font-size:1rem;font-weight:500;color:var(--muted);letter-spacing:.01em;margin-bottom:20px;line-height:1.5;}
.hero-role strong{color:var(--txt2);}
.hero-desc{font-size:.93rem;color:var(--muted);line-height:1.75;margin-bottom:36px;max-width:480px;}
.cta-row{display:flex;gap:12px;flex-wrap:wrap;}
.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 24px;border-radius:4px;
  font-family:var(--fh);font-weight:700;font-size:.82rem;letter-spacing:.04em;cursor:pointer;text-decoration:none;transition:all .2s;}
.btn-primary{background:var(--acc);color:#fff;}
.btn-primary:hover{background:var(--acc2);color:#fff;transform:translateY(-2px);box-shadow:0 8px 28px var(--acc-glow);}
.btn-ghost{background:transparent;color:var(--txt2);border:1px solid var(--border2);}
.btn-ghost:hover{border-color:var(--acc);color:var(--acc);}
.hero-stats{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:8px;overflow:hidden;}
.hstat{background:var(--bg2);padding:22px 18px;transition:background .2s;}
.hstat:hover{background:var(--surface);}
.hstat-v{font-family:var(--fh);font-size:1.85rem;font-weight:800;color:var(--acc);line-height:1;}
.hstat-l{font-size:.73rem;color:var(--muted);margin-top:5px;line-height:1.4;}
.hstat-s{font-size:.67rem;color:var(--border2);margin-top:2px;}
/* SECTIONS */
.section{padding:88px 0;}
.section.alt{background:var(--alt);}
.container{max-width:1140px;margin:0 auto;padding:0 40px;}
.sec-hd{margin-bottom:48px;}
.stag{font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;color:var(--acc);margin-bottom:10px;display:block;font-weight:500;}
.sec-hd h2{font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:800;color:var(--txt);margin-bottom:10px;}
.sdesc{font-size:.93rem;color:var(--muted);max-width:560px;line-height:1.7;margin:0;}
.sub-h{font-family:var(--fh);font-size:1.15rem;font-weight:700;color:var(--txt);margin-bottom:16px;}
.sub-h2{font-family:var(--fh);font-size:.95rem;font-weight:700;color:var(--txt);margin-bottom:10px;}
/* ABOUT */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:40px;}
.principles{display:flex;flex-direction:column;gap:12px;margin-top:24px;}
.principle{display:flex;gap:12px;padding:12px 14px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;border-left:2px solid var(--acc);}
.p-ic{font-size:1rem;flex-shrink:0;margin-top:2px;}
.principle strong{font-size:.87rem;color:var(--txt);display:block;margin-bottom:2px;}
.p-d{font-size:.78rem;color:var(--muted);}
.title-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;overflow:hidden;}
.tc-head{padding:16px 20px;border-bottom:1px solid var(--border);background:var(--surface);}
.tc-head h3{font-size:.95rem;color:var(--txt);margin-bottom:3px;}
.tc-head p{font-size:.76rem;color:var(--muted);margin:0;}
.tc-rows{padding:4px 0;}
.tr{display:grid;grid-template-columns:1fr auto auto;gap:8px 14px;align-items:center;padding:9px 20px;border-bottom:1px solid var(--border);font-size:.83rem;color:var(--txt2);}
.tr:last-child{border-bottom:none;}
.tr.best{background:var(--acc-glow);color:var(--txt);font-weight:500;}
.badge{font-size:.61rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:2px 7px;border-radius:3px;}
.bb{background:var(--acc-glow);color:var(--acc);}
.bc{background:rgba(255,255,255,.06);color:var(--txt2);}
.bp{background:rgba(255,255,255,.03);color:var(--muted);}
.tn{font-size:.7rem;color:var(--muted);text-align:right;}
.ambition{margin:16px 20px;padding:12px 14px;background:var(--acc-glow);border:1px solid rgba(255,255,255,.06);border-radius:6px;font-size:.83rem;color:var(--txt2);line-height:1.6;}
.ambition strong{color:var(--acc);}
/* FRAMEWORK */
.fw-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.fw-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:20px;position:relative;overflow:hidden;transition:all .2s;}
.fw-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--acc);transform:scaleX(0);transform-origin:left;transition:transform .3s;}
.fw-card:hover::before{transform:scaleX(1);}
.fw-card:hover{border-color:var(--border2);}
.fw-n{font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;color:var(--acc);margin-bottom:9px;font-weight:500;}
.fw-t{font-family:var(--fh);font-size:.98rem;font-weight:700;color:var(--txt);margin-bottom:6px;}
.fw-d{font-size:.8rem;color:var(--muted);line-height:1.6;margin-bottom:9px;}
.fw-tools{font-size:.69rem;color:var(--border2);letter-spacing:.02em;}
/* CTX BOX */
.ctx-box{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:20px 22px;margin-bottom:30px;}
.ctx-g{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.ci label{display:block;font-size:.64rem;letter-spacing:.1em;text-transform:uppercase;color:var(--acc);margin-bottom:3px;font-weight:500;}
.ci span{font-size:.85rem;color:var(--txt2);}
/* METRICS STRIP */
.mstrip{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border-radius:8px;overflow:hidden;margin:32px 0;}
.ms{background:var(--bg2);padding:20px 16px;text-align:center;}
.ms.hi{background:var(--acc);}
.msv{font-family:var(--fh);font-size:1.7rem;font-weight:800;color:var(--acc);line-height:1;}
.ms.hi .msv{color:#fff;}
.msl{font-size:.7rem;color:var(--muted);margin-top:4px;line-height:1.35;}
.ms.hi .msl{color:rgba(255,255,255,.7);}
/* TABLE */
.tw{overflow-x:auto;border-radius:6px;border:1px solid var(--border);}
table{width:100%;border-collapse:collapse;font-size:.81rem;}
thead tr{background:var(--surface);}
thead th{padding:9px 12px;text-align:left;font-family:var(--fh);font-weight:700;font-size:.75rem;color:var(--txt);letter-spacing:.03em;white-space:nowrap;}
tbody tr{border-bottom:1px solid var(--border);transition:background .15s;}
tbody tr:hover{background:var(--surface);}
tbody tr:last-child{background:var(--acc-glow);font-weight:600;}
tbody tr:last-child td{color:var(--txt);}
td{padding:8px 12px;color:var(--txt2);}
td.hi{color:var(--acc);font-weight:600;}
td.ok{color:var(--ok);}
.tbl-h{font-family:var(--fh);font-size:.95rem;font-weight:700;color:var(--txt);margin-bottom:12px;}
.tbl-note{font-size:.71rem;color:var(--muted);margin-top:6px;font-style:italic;}
/* BARRIERS */
.barriers{display:flex;flex-direction:column;gap:12px;}
.barrier{display:grid;grid-template-columns:38px 1fr;gap:14px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:16px;border-left:2px solid var(--acc);}
.bn{font-family:var(--fh);font-weight:800;font-size:1.3rem;color:var(--acc);line-height:1;padding-top:2px;}
.bt{font-family:var(--fh);font-weight:700;font-size:.87rem;color:var(--txt);margin-bottom:4px;}
.bd{font-size:.8rem;color:var(--muted);line-height:1.55;}
/* PHASES */
.phases{display:flex;flex-direction:column;gap:10px;}
.phase{background:var(--bg2);border:1px solid var(--border);border-radius:6px;overflow:hidden;}
.ph{display:flex;align-items:center;gap:14px;padding:13px 18px;cursor:pointer;user-select:none;}
.ph:hover{background:var(--surface);}
.pn{width:28px;height:28px;border-radius:50%;background:var(--acc);color:#fff;font-family:var(--fh);font-weight:800;font-size:.78rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.pt{font-family:var(--fh);font-weight:700;font-size:.88rem;color:var(--txt);}
.ps{font-size:.76rem;color:var(--muted);margin-top:2px;}
.pb{padding:4px 18px 14px 60px;display:block;}
.pb li{font-size:.81rem;color:var(--txt2);padding:4px 0 4px 14px;position:relative;line-height:1.5;}
.pb li::before{content:'▸';position:absolute;left:0;color:var(--acc);font-size:.7rem;top:5px;}
/* OPT */
.opt-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.oc{border-radius:8px;padding:18px;border:1px solid var(--border);background:var(--bg2);}
.ot{font-size:.64rem;letter-spacing:.1em;text-transform:uppercase;color:var(--acc);margin-bottom:8px;font-weight:500;}
.oba{display:flex;align-items:center;gap:8px;margin:8px 0;font-size:.87rem;}
.ob{color:var(--muted);text-decoration:line-through;}
.oa-arr{color:var(--acc);}
.oa{color:var(--acc);font-weight:600;}
.on{font-size:.77rem;color:var(--muted);font-style:italic;margin-top:6px;}
.oc p{font-size:.81rem;color:var(--muted);line-height:1.55;margin:0;}
/* LTV */
.ltv-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
.ltv-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:24px;}
.ltv-card h3{font-family:var(--fh);font-size:.95rem;color:var(--acc);margin-bottom:16px;}
.lr{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:.83rem;}
.lr:last-child{border-bottom:none;}
.ll{color:var(--muted);}
.lv{color:var(--txt);font-weight:500;}
.lv.big{font-family:var(--fh);font-size:1.25rem;font-weight:800;color:var(--acc);}
.lv.hl{color:var(--acc);}
/* IMPACT */
.impact-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:22px;}
.ii{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:16px;border-left:2px solid var(--acc);}
.it{font-family:var(--fh);font-weight:700;font-size:.87rem;color:var(--acc);margin-bottom:4px;}
.id{font-size:.79rem;color:var(--muted);line-height:1.55;}
/* GP */
.gp-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;}
.gp{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:20px;}
.gp-pri{font-size:.64rem;letter-spacing:.12em;text-transform:uppercase;color:var(--acc);font-weight:600;margin-bottom:7px;}
.gp-t{font-family:var(--fh);font-weight:700;font-size:.93rem;color:var(--txt);margin-bottom:8px;}
.gp-b{font-size:.81rem;color:var(--muted);line-height:1.6;}
.gp-a{margin-top:10px;padding:9px 11px;background:var(--acc-glow);border:1px solid rgba(255,255,255,.05);border-radius:4px;font-size:.79rem;color:var(--txt2);line-height:1.5;}
.gp-a strong{color:var(--acc);}
/* CS2/CS3 */
.ctr-bars{display:flex;flex-direction:column;gap:9px;}
.ctr-r label{display:flex;justify-content:space-between;font-size:.74rem;color:var(--muted);margin-bottom:3px;}
.hi-t{color:var(--acc);font-weight:600;}
.ctr-t{height:7px;background:var(--surface);border-radius:100px;overflow:hidden;}
.ctr-f{height:100%;border-radius:100px;background:linear-gradient(90deg,var(--acc3),var(--acc));}
.pills{display:flex;flex-wrap:wrap;gap:8px;margin:14px 0;}
.pill{padding:5px 12px;background:var(--surface);border:1px solid var(--border);border-radius:4px;font-size:.77rem;color:var(--txt2);}
.pill strong{color:var(--acc);}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:20px;}
.card-t{font-family:var(--fh);font-weight:700;font-size:.93rem;color:var(--txt);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.card-t::before{content:'';display:inline-block;width:12px;height:2px;background:var(--acc);border-radius:2px;}
.bl{list-style:none;display:flex;flex-direction:column;gap:6px;}
.bl li{font-size:.81rem;color:var(--txt2);padding-left:14px;position:relative;line-height:1.5;}
.bl li::before{content:'→';position:absolute;left:0;color:var(--acc);font-size:.69rem;top:2px;}
.note-box{margin-top:12px;padding:11px 13px;background:var(--acc-glow);border:1px solid rgba(255,255,255,.06);border-radius:6px;font-size:.8rem;color:var(--txt2);}
.note-box strong{color:var(--acc);}
.dk-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:20px 0;}
.dks{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:16px 12px;text-align:center;}
.dksv{font-family:var(--fh);font-size:1.5rem;font-weight:800;color:var(--acc);}
.dksl{font-size:.7rem;color:var(--muted);margin-top:3px;}
/* ENGAGEMENT */
.eng-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.ec{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:24px;position:relative;overflow:hidden;transition:all .2s;}
.ec::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--border2);}
.ec.feat{border-color:var(--acc-glow);}
.ec.feat::after{background:var(--acc);}
.ec:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,.3);}
.et{font-size:.64rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:8px;font-weight:500;}
.ec.feat .et{color:var(--acc);}
.etitle{font-family:var(--fh);font-weight:700;font-size:1.02rem;color:var(--txt);margin-bottom:4px;}
.etl{font-size:.77rem;color:var(--muted);margin-bottom:14px;}
.eprice{font-family:var(--fh);font-size:1.35rem;font-weight:800;color:var(--acc);margin:12px 0;}
.einc{display:flex;flex-direction:column;gap:5px;font-size:.79rem;color:var(--muted);}
.einc span::before{content:'✓ ';color:var(--acc);}
.incl-box{margin-top:18px;padding:14px 18px;background:var(--surface);border:1px solid var(--border);border-radius:6px;font-size:.81rem;color:var(--txt2);}
/* CONTACT */
.contact-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:start;}
.cquote{font-family:var(--fh);font-size:1.55rem;font-weight:800;color:var(--txt);line-height:1.3;margin-bottom:20px;}
.cquote em{color:var(--acc);font-style:normal;}
.clinks{display:flex;flex-direction:column;gap:10px;margin-top:22px;}
.cl{display:flex;align-items:center;gap:12px;font-size:.86rem;padding:11px 14px;background:var(--bg2);border:1px solid var(--border);border-radius:6px;transition:border-color .2s;color:var(--txt2);}
.cl:hover{border-color:var(--acc);}
.ci-icon{width:30px;height:30px;background:var(--surface);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:.85rem;flex-shrink:0;}
.copts{display:flex;flex-direction:column;gap:12px;}
.co{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:16px 18px;}
.co-t{font-family:var(--fh);font-weight:700;font-size:.9rem;color:var(--txt);margin-bottom:4px;}
.co-d{font-size:.79rem;color:var(--muted);margin:0 0 7px;}
.co a{font-size:.79rem;}
/* FOOTER */
footer{background:var(--bg2);border-top:1px solid var(--border);padding:18px 40px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;}
footer p{font-size:.72rem;color:var(--muted);margin:0;}
/* REVEAL */
.R{opacity:0;transform:translateY(20px);transition:opacity .5s ease,transform .5s ease;}
.R.vis{opacity:1;transform:translateY(0);}
/* RESPONSIVE */
@media(max-width:900px){
  .hero-inner,.two-col,.ltv-grid,.contact-grid{grid-template-columns:1fr;}
  .fw-grid,.gp-grid,.dk-stats{grid-template-columns:repeat(2,1fr);}
  .mstrip,.eng-grid,.opt-grid,.ctx-g{grid-template-columns:repeat(2,1fr);}
  .hero-stats{grid-template-columns:repeat(2,1fr);}
  .nav-links{display:none;}
}
@media(max-width:540px){
  .fw-grid,.gp-grid,.dk-stats,.mstrip,.eng-grid,.opt-grid{grid-template-columns:1fr;}
  .container{padding:0 18px;}
}

#hero{ background:radial-gradient(ellipse 80% 60% at 60% 40%,rgba(10,191,204,.07) 0%,transparent 70%),var(--bg); }
/* light theme overrides */





</style>
</head>
