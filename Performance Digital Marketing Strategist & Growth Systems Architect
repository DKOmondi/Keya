<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Daniel K Omondi — Portfolio 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════
   TOKENS & RESET
═══════════════════════════════════════════════ */
:root {
  --orange:      #E8640A;
  --orange-lt:   #F28340;
  --teal:        #0A7E8C;
  --teal-dk:     #065966;
  --teal-lt:     #E6F4F5;
  --gold:        #C89B3C;
  --charcoal:    #1A1A2E;
  --ink:         #2C2C3E;
  --muted:       #7A7A9A;
  --border:      #C8DEE0;
  --bg:          #F6FAFA;
  --white:       #FFFFFF;
  --card-bg:     #FFFFFF;

  --font-display: 'Syne', sans-serif;
  --font-body:    'DM Sans', sans-serif;
  --font-mono:    'DM Mono', monospace;

  --r-sm: 6px;
  --r-md: 12px;
  --r-lg: 20px;
  --shadow: 0 2px 16px rgba(6,89,102,0.08);
  --shadow-lg: 0 8px 40px rgba(6,89,102,0.13);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; font-size: 15px; }

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--ink);
  line-height: 1.65;
  overflow-x: hidden;
}

/* ═══════════════════════════════════════════════
   TYPOGRAPHY
═══════════════════════════════════════════════ */
h1,h2,h3,h4 { font-family: var(--font-display); line-height: 1.15; }
.display-xl  { font-size: clamp(3rem,8vw,6rem); font-weight:800; letter-spacing:-0.03em; }
.display-lg  { font-size: clamp(1.8rem,4vw,2.8rem); font-weight:700; letter-spacing:-0.02em; }
.display-md  { font-size: 1.35rem; font-weight:700; }
.section-tag { font-family:var(--font-mono); font-size:0.72rem; letter-spacing:0.12em;
               text-transform:uppercase; color:var(--teal); }
.label-sm    { font-family:var(--font-mono); font-size:0.68rem; letter-spacing:0.1em;
               text-transform:uppercase; color:var(--muted); }
p            { color:var(--ink); margin-bottom:0.7em; }
strong, b    { font-weight:600; }
a            { color:var(--teal); text-decoration:none; }
a:hover      { color:var(--orange); }

/* ═══════════════════════════════════════════════
   LAYOUT
═══════════════════════════════════════════════ */
.container { max-width:1120px; margin:0 auto; padding:0 32px; }

/* ═══════════════════════════════════════════════
   NAV
═══════════════════════════════════════════════ */
nav {
  position: fixed; top:0; left:0; right:0; z-index:100;
  background: rgba(26,26,46,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(10,126,140,0.25);
  padding: 0 32px;
  display: flex; align-items:center; justify-content:space-between;
  height: 56px;
}
.nav-name {
  font-family:var(--font-display); font-weight:700; font-size:0.9rem;
  letter-spacing:0.04em; color:var(--white);
}
.nav-name span { color:var(--orange); }
.nav-links { display:flex; gap:24px; }
.nav-links a {
  font-size:0.78rem; font-weight:500; color:rgba(255,255,255,0.65);
  letter-spacing:0.06em; text-transform:uppercase;
  transition: color 0.2s;
}
.nav-links a:hover { color:var(--teal); }

/* ═══════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════ */
#hero {
  min-height: 100vh;
  background: var(--charcoal);
  display: flex; align-items:center;
  position: relative; overflow: hidden;
  padding-top: 56px;
}
.hero-grid-bg {
  position:absolute; inset:0; pointer-events:none;
  background-image:
    linear-gradient(rgba(10,126,140,0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(10,126,140,0.06) 1px, transparent 1px);
  background-size: 48px 48px;
  animation: gridPan 40s linear infinite;
}
@keyframes gridPan { from{background-position:0 0} to{background-position:48px 48px} }

.hero-glow {
  position:absolute; width:600px; height:600px; border-radius:50%;
  background: radial-gradient(circle, rgba(10,126,140,0.18) 0%, transparent 70%);
  top:-100px; right:-100px; pointer-events:none;
  animation: glowPulse 6s ease-in-out infinite;
}
.hero-glow-2 {
  position:absolute; width:400px; height:400px; border-radius:50%;
  background: radial-gradient(circle, rgba(232,100,10,0.12) 0%, transparent 70%);
  bottom:-80px; left:80px; pointer-events:none;
  animation: glowPulse 8s ease-in-out infinite reverse;
}
@keyframes glowPulse { 0%,100%{opacity:0.7;transform:scale(1)} 50%{opacity:1;transform:scale(1.1)} }

.hero-inner {
  position:relative; z-index:2;
  display:grid; grid-template-columns:1fr 1fr; gap:64px;
  align-items:center; padding: 80px 0;
}
.hero-badge {
  display:inline-flex; align-items:center; gap:8px;
  background: rgba(10,126,140,0.15); border:1px solid rgba(10,126,140,0.35);
  border-radius:100px; padding:4px 14px 4px 4px;
  margin-bottom:24px;
}
.hero-badge-dot {
  width:8px; height:8px; border-radius:50%; background:var(--teal);
  animation: blink 2s ease-in-out infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.hero-badge span { font-size:0.72rem; color:var(--teal); font-weight:500; letter-spacing:0.06em; }

.hero-name { color:var(--white); margin-bottom:4px; }
.hero-name em { color:var(--orange); font-style:normal; }
.hero-title-line {
  font-family:var(--font-display); font-size:clamp(1rem,2.2vw,1.3rem);
  font-weight:600; color:var(--teal); margin-bottom:20px; letter-spacing:-0.01em;
}
.hero-desc {
  font-size:1rem; color:rgba(255,255,255,0.65); line-height:1.7;
  margin-bottom:32px; max-width:460px;
}
.hero-cta-row { display:flex; gap:12px; flex-wrap:wrap; }
.btn-primary {
  background:var(--orange); color:var(--white); border:none;
  padding:11px 26px; border-radius:var(--r-sm); font-family:var(--font-display);
  font-weight:700; font-size:0.85rem; letter-spacing:0.04em; cursor:pointer;
  text-decoration:none; display:inline-block;
  transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
}
.btn-primary:hover { background:var(--orange-lt); color:var(--white); transform:translateY(-2px); box-shadow:0 6px 20px rgba(232,100,10,0.35); }
.btn-ghost {
  background:transparent; color:rgba(255,255,255,0.75); border:1px solid rgba(255,255,255,0.2);
  padding:11px 26px; border-radius:var(--r-sm); font-family:var(--font-display);
  font-weight:600; font-size:0.85rem; letter-spacing:0.04em; cursor:pointer;
  text-decoration:none; display:inline-block;
  transition: border-color 0.2s, color 0.2s;
}
.btn-ghost:hover { border-color:var(--teal); color:var(--teal); }

.hero-stats { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; }
.stat-card {
  background: rgba(255,255,255,0.04); border:1px solid rgba(10,126,140,0.2);
  border-radius:var(--r-md); padding:20px 18px;
  transition: border-color 0.2s, background 0.2s;
  animation: fadeUp 0.6s ease both;
}
.stat-card:hover { border-color:rgba(10,126,140,0.5); background:rgba(10,126,140,0.06); }
.stat-val {
  font-family:var(--font-display); font-size:1.9rem; font-weight:800;
  color:var(--orange); line-height:1;
}
.stat-label { font-size:0.72rem; color:rgba(255,255,255,0.5); margin-top:4px; line-height:1.4; }

/* ═══════════════════════════════════════════════
   SECTION WRAPPER
═══════════════════════════════════════════════ */
.section { padding:80px 0; }
.section-alt { background:var(--white); }
.section-dark { background:var(--charcoal); }
.section-teal { background:var(--teal-dk); }

.section-header { margin-bottom:48px; }
.section-header .section-tag { margin-bottom:8px; display:block; }
.section-header h2 { margin-bottom:10px; color:var(--teal-dk); }
.section-header p { color:var(--muted); max-width:560px; font-size:0.95rem; }
.section-dark .section-header h2 { color:var(--white); }
.section-dark .section-header p  { color:rgba(255,255,255,0.55); }

/* ═══════════════════════════════════════════════
   ABOUT
═══════════════════════════════════════════════ */
.about-grid { display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:start; }
.about-text p { font-size:1rem; line-height:1.75; }
.principle-list { margin-top:24px; display:flex; flex-direction:column; gap:12px; }
.principle-item {
  display:flex; gap:14px; align-items:flex-start;
  padding:14px 16px; background:var(--teal-lt);
  border-radius:var(--r-sm); border-left:3px solid var(--teal);
}
.principle-icon { font-size:1.1rem; line-height:1; margin-top:2px; flex-shrink:0; }
.principle-text strong { color:var(--teal-dk); font-size:0.9rem; display:block; margin-bottom:2px; }
.principle-text span { font-size:0.82rem; color:var(--muted); }

.title-card {
  background:var(--charcoal); border-radius:var(--r-lg); padding:32px;
  color:var(--white);
}
.title-card h3 { font-size:1.1rem; color:var(--teal); margin-bottom:20px; }
.title-row {
  display:grid; grid-template-columns:1fr auto auto; gap:10px 16px;
  align-items:center; padding:10px 0;
  border-bottom:1px solid rgba(255,255,255,0.06);
  font-size:0.85rem;
}
.title-row:last-child { border-bottom:none; }
.title-name { color:rgba(255,255,255,0.8); }
.title-badge {
  font-size:0.65rem; font-weight:700; letter-spacing:0.07em; text-transform:uppercase;
  padding:2px 8px; border-radius:100px;
}
.badge-best  { background:rgba(10,126,140,0.25); color:var(--teal); }
.badge-close { background:rgba(200,155,60,0.2); color:var(--gold); }
.badge-part  { background:rgba(255,255,255,0.06); color:var(--muted); }
.ambition-box {
  margin-top:24px; padding:16px 18px;
  background:linear-gradient(135deg,rgba(10,126,140,0.15),rgba(232,100,10,0.1));
  border:1px solid rgba(10,126,140,0.3); border-radius:var(--r-md);
  font-size:0.88rem; color:rgba(255,255,255,0.8); line-height:1.6;
}
.ambition-box strong { color:var(--orange); }

/* ═══════════════════════════════════════════════
   FRAMEWORK
═══════════════════════════════════════════════ */
.framework-steps { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
.step-card {
  background:var(--white); border:1px solid var(--border);
  border-radius:var(--r-md); padding:24px 20px;
  position:relative; overflow:hidden;
  transition:transform 0.2s, box-shadow 0.2s;
}
.step-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-lg); }
.step-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background:var(--teal);
}
.step-num {
  font-family:var(--font-mono); font-size:0.7rem; color:var(--muted);
  letter-spacing:0.1em; margin-bottom:10px;
}
.step-title { font-family:var(--font-display); font-size:1rem; font-weight:700; color:var(--teal-dk); margin-bottom:6px; }
.step-desc { font-size:0.82rem; color:var(--muted); line-height:1.55; margin-bottom:10px; }
.step-tools { font-family:var(--font-mono); font-size:0.68rem; color:var(--teal); line-height:1.5; }

/* ═══════════════════════════════════════════════
   CASE STUDY — THERMOTEQ
═══════════════════════════════════════════════ */
.case-hero {
  display:grid; grid-template-columns:1fr 1.1fr; gap:56px; align-items:start;
}
.case-eyebrow {
  display:flex; align-items:center; gap:10px; margin-bottom:16px;
}
.case-logo {
  font-family:var(--font-display); font-weight:800; font-size:1.1rem;
  padding:6px 14px; border-radius:var(--r-sm);
  background:rgba(232,100,10,0.1); color:var(--orange); border:1px solid rgba(232,100,10,0.25);
}
.case-period {
  font-family:var(--font-mono); font-size:0.7rem; color:var(--muted);
  letter-spacing:0.06em;
}
.case-intro { font-size:0.95rem; color:var(--ink); line-height:1.75; margin-bottom:20px; }
.barrier-list { display:flex; flex-direction:column; gap:10px; margin-top:12px; }
.barrier {
  display:flex; gap:12px; padding:12px 14px;
  background:rgba(232,100,10,0.05); border:1px solid rgba(232,100,10,0.15);
  border-radius:var(--r-sm);
}
.barrier-num { font-family:var(--font-display); font-weight:800; font-size:1.1rem; color:var(--orange); flex-shrink:0; line-height:1.2; }
.barrier-body strong { display:block; font-size:0.85rem; color:var(--teal-dk); margin-bottom:2px; }
.barrier-body span { font-size:0.8rem; color:var(--muted); }

/* Metrics grid */
.metrics-grid {
  display:grid; grid-template-columns:repeat(4,1fr); gap:1px;
  background:var(--border); border-radius:var(--r-md); overflow:hidden;
  margin:32px 0;
}
.metric-cell {
  background:var(--white); padding:20px 16px; text-align:center;
}
.metric-val {
  font-family:var(--font-display); font-size:1.7rem; font-weight:800; color:var(--orange);
  line-height:1;
}
.metric-lbl { font-size:0.71rem; color:var(--muted); margin-top:4px; line-height:1.4; }
.metric-cell.highlight { background:var(--teal-dk); }
.metric-cell.highlight .metric-val { color:var(--white); }
.metric-cell.highlight .metric-lbl { color:rgba(255,255,255,0.6); }

/* Spend / Revenue tables */
.data-table { width:100%; border-collapse:collapse; font-size:0.83rem; }
.data-table thead tr { background:var(--teal-dk); color:var(--white); }
.data-table thead th { padding:9px 12px; text-align:left; font-family:var(--font-display); font-weight:600; font-size:0.78rem; letter-spacing:0.03em; }
.data-table tbody tr { border-bottom:1px solid var(--border); }
.data-table tbody tr:nth-child(even) { background:var(--teal-lt); }
.data-table tbody tr:last-child { background:rgba(10,126,140,0.08); font-weight:600; }
.data-table td { padding:8px 12px; color:var(--ink); }
.data-table td:not(:first-child) { font-family:var(--font-mono); font-size:0.8rem; }
.num-up { color:var(--teal); font-weight:600; }
.num-dn { color:var(--orange); font-weight:600; }

/* Two-col cards */
.two-col { display:grid; grid-template-columns:1fr 1fr; gap:24px; }
.info-card {
  background:var(--white); border:1px solid var(--border); border-radius:var(--r-md);
  padding:24px 22px; box-shadow:var(--shadow);
}
.info-card h4 { font-family:var(--font-display); font-size:0.95rem; color:var(--teal-dk); margin-bottom:14px; display:flex; align-items:center; gap:8px; }
.info-card h4::before { content:''; display:inline-block; width:12px; height:3px; background:var(--orange); border-radius:2px; }
.bullet-list { list-style:none; display:flex; flex-direction:column; gap:7px; }
.bullet-list li { font-size:0.83rem; color:var(--ink); padding-left:16px; position:relative; line-height:1.5; }
.bullet-list li::before { content:'▸'; position:absolute; left:0; color:var(--teal); font-size:0.7rem; top:2px; }

/* Channel table */
.channel-table-wrap { overflow-x:auto; border-radius:var(--r-md); box-shadow:var(--shadow); }

/* Phase accordion */
.phases { display:flex; flex-direction:column; gap:14px; margin:20px 0; }
.phase-item {
  border:1px solid var(--border); border-radius:var(--r-md); overflow:hidden;
  background:var(--white);
}
.phase-header {
  display:flex; align-items:center; gap:14px; padding:14px 18px;
  cursor:pointer; user-select:none;
}
.phase-num {
  width:30px; height:30px; border-radius:50%; background:var(--teal-dk); color:var(--white);
  font-family:var(--font-display); font-weight:800; font-size:0.8rem;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.phase-title { font-family:var(--font-display); font-weight:700; font-size:0.9rem; color:var(--teal-dk); }
.phase-sub { font-size:0.78rem; color:var(--muted); margin-top:1px; }
.phase-body { padding:0 18px 16px 62px; font-size:0.83rem; }
.phase-body ul { list-style:none; display:flex; flex-direction:column; gap:6px; }
.phase-body li { position:relative; padding-left:14px; color:var(--ink); }
.phase-body li::before { content:'→'; position:absolute; left:0; color:var(--teal); font-size:0.7rem; top:1px; }

/* Optimisation cards */
.opt-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-top:20px; }
.opt-card {
  border-radius:var(--r-md); padding:20px; position:relative; overflow:hidden;
}
.opt-card-1 { background:linear-gradient(135deg,var(--teal-lt),rgba(10,126,140,0.05)); border:1px solid rgba(10,126,140,0.2); }
.opt-card-2 { background:linear-gradient(135deg,rgba(200,155,60,0.08),rgba(200,155,60,0.03)); border:1px solid rgba(200,155,60,0.2); }
.opt-card-3 { background:linear-gradient(135deg,rgba(232,100,10,0.07),rgba(232,100,10,0.02)); border:1px solid rgba(232,100,10,0.15); }
.opt-tag { font-family:var(--font-mono); font-size:0.65rem; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:8px; }
.opt-card-1 .opt-tag { color:var(--teal); }
.opt-card-2 .opt-tag { color:var(--gold); }
.opt-card-3 .opt-tag { color:var(--orange); }
.opt-before-after { display:flex; align-items:center; gap:8px; margin:10px 0; font-family:var(--font-mono); font-size:0.85rem; }
.opt-before { color:var(--muted); text-decoration:line-through; }
.opt-arrow { color:var(--teal); font-size:0.8rem; }
.opt-after { color:var(--teal-dk); font-weight:600; }
.opt-insight { font-size:0.78rem; color:var(--muted); font-style:italic; margin-top:8px; }

/* Impact list */
.impact-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:16px; margin-top:20px; }
.impact-item {
  background:rgba(255,255,255,0.05); border:1px solid rgba(10,126,140,0.2);
  border-radius:var(--r-md); padding:18px 16px;
}
.impact-title { font-family:var(--font-display); font-weight:700; font-size:0.88rem; color:var(--teal); margin-bottom:6px; }
.impact-desc { font-size:0.82rem; color:rgba(255,255,255,0.65); line-height:1.55; }

/* ═══════════════════════════════════════════════
   CASE STUDY 2 — NCHITV
═══════════════════════════════════════════════ */
.nchitv-grid { display:grid; grid-template-columns:1fr 1fr; gap:40px; }
.ctr-bar-wrap { margin:16px 0; }
.ctr-bar-label { display:flex; justify-content:space-between; font-size:0.78rem; color:var(--muted); margin-bottom:4px; }
.ctr-bar-track { height:10px; background:var(--border); border-radius:100px; overflow:hidden; }
.ctr-bar-fill { height:100%; border-radius:100px; background:linear-gradient(90deg,var(--teal),var(--orange)); }

/* ═══════════════════════════════════════════════
   CASE STUDY 3 — DKBRIEFS
═══════════════════════════════════════════════ */
.dkb-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin:24px 0; }
.dkb-stat { text-align:center; padding:18px 12px; background:rgba(255,255,255,0.04); border:1px solid rgba(10,126,140,0.2); border-radius:var(--r-md); }
.dkb-val { font-family:var(--font-display); font-size:1.5rem; font-weight:800; color:var(--orange); }
.dkb-lbl { font-size:0.7rem; color:rgba(255,255,255,0.5); margin-top:3px; }

/* ═══════════════════════════════════════════════
   LTV / CAC SECTION
═══════════════════════════════════════════════ */
.ltv-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px; }
.ltv-card {
  border-radius:var(--r-lg); padding:28px;
  background:linear-gradient(135deg,var(--teal-dk) 0%,var(--charcoal) 100%);
  color:var(--white);
}
.ltv-card h3 { font-size:1rem; color:var(--teal); margin-bottom:18px; }
.ltv-row { display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.06); font-size:0.84rem; }
.ltv-row:last-child { border-bottom:none; }
.ltv-row-lbl { color:rgba(255,255,255,0.65); }
.ltv-row-val { font-family:var(--font-mono); color:var(--white); font-weight:500; }
.ltv-row-val.highlight { color:var(--orange); font-weight:700; }
.ltv-row-val.big { font-family:var(--font-display); font-size:1.25rem; font-weight:800; color:var(--orange); }

/* ═══════════════════════════════════════════════
   ENGAGEMENT OPTIONS
═══════════════════════════════════════════════ */
.eng-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
.eng-card {
  border-radius:var(--r-lg); padding:28px; background:var(--white);
  border:1px solid var(--border); position:relative; overflow:hidden;
  transition:transform 0.2s, box-shadow 0.2s;
}
.eng-card:hover { transform:translateY(-6px); box-shadow:var(--shadow-lg); }
.eng-card.featured { background:var(--teal-dk); border-color:var(--teal); }
.eng-card::after {
  content:''; position:absolute; to
